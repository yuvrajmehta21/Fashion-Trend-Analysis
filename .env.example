# Fashion Trend Analysis — environment template.
# Copy to .env and fill in. NEVER commit the real .env.

# --- Instagram trend signal (Apify) ---------------------------------------
# Pay-per-result with a $5/month free credit and NO minimum deposit. The
# apify/instagram-scraper actor costs $0.0027/result on the free tier; the
# current source list is ~246 results/run (~$0.66), ~$2.86/mo — inside the
# free credit. Token: https://console.apify.com/settings/integrations
# Leave blank to disable Instagram (the rest of the tracker still runs).
# APIFY_TOKEN=

# --- Vision fallback (OPTIONAL, paid) -------------------------------------
# Only used for garments FashionCLIP can't tag confidently. Leave blank to
# disable the fallback entirely (the tracker still runs on FashionCLIP alone).
# We will NOT enable this without your explicit go-ahead.
# ANTHROPIC_API_KEY=

# --- Weekly report delivery (OPTIONAL) ------------------------------------
# Same Gmail SMTP pattern as the best seller agent. Leave blank while iterating;
# the PDF is still written locally to .tmp/ regardless.
# REPORT_EMAILS=
# REPORT_SHARING_ENABLED=false
# EMAIL_FROM_ADDRESS=
# EMAIL_FROM_APP_PASSWORD=
